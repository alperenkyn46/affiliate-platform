# Server
PORT=5000
NODE_ENV=production

# Database (Railway MySQL veya PlanetScale)
DB_HOST=your-database-host.railway.app
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_secure_password
DB_NAME=affiliate_db
DB_SSL=true

# JWT (Production için güçlü bir secret kullan!)
JWT_SECRET=your_super_secret_jwt_key_min_32_characters
JWT_EXPIRES_IN=7d

# CORS - Frontend URL
FRONTEND_URL=https://your-frontend.vercel.app

# E-posta (Opsiyonel - SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_EMAIL=

# Yedekleme
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
